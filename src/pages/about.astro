---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`关于 · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
				line-height: 1.7;
				color: rgb(var(--gray-dark));
			}
			h1 {
				margin-bottom: 1em;
				font-size: 2em;
			}
			.section {
				margin-bottom: 2.5em;
			}
			.section h2 {
				font-size: 1.3em;
				margin-bottom: 0.6em;
				color: rgb(var(--black));
			}
			.section p {
				margin: 0.6em 0;
			}
			.links {
				display: flex;
				gap: 1em;
				flex-wrap: wrap;
				margin-top: 1em;
			}
			.links a {
				color: rgb(var(--accent));
				text-decoration: none;
				padding: 0.3em 0.8em;
				border: 1px solid rgb(var(--accent));
				border-radius: 999px;
				font-size: 0.9em;
			}
			.links a:hover {
				background: rgb(var(--accent));
				color: white;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>关于</h1>

			<section class="section">
				<h2>我是谁</h2>
				<p>老胡。40 岁，15 年 UI/平面/可视化大屏设计经验。当前全职探索 AI 时代的个人转型路径。</p>
			</section>

			<section class="section">
				<h2>这个网站</h2>
				<p>个人内容合集站。承载 5 类内容：</p>
				<p>
					<strong>博客 / 日记</strong> · 每日 Obsidian 产出
					<br />
					<strong>设计作品</strong> · UI 案例展示
					<br />
					<strong>打卡表</strong> · 习惯追踪
					<br />
					<strong>工具库</strong> · 后续演变为 AI 工具导航站
					<br />
					<strong>独立产品</strong> · 产品落地页
				</p>
				<p>技术栈：Astro + Content Collections + 腾讯云 EdgeOne Pages。0 成本，国内可访问。</p>
			</section>

			<section class="section">
				<h2>导航</h2>
				<div class="links">
					<a href="/posts">博客</a>
					<a href="/checkins">打卡</a>
					<a href="/tools">工具库</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
